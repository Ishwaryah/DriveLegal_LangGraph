{
  "metadata": {
    "source": "Central Motor Vehicles Rules, 1989 + MV Act 1988 Schedule",
    "last_updated": "2026-05-01"
  },
  "vehicle_categories": {
    "LMV": {
      "full_name": "Light Motor Vehicle",
      "description": "Vehicle with GVW not exceeding 7500 kg",
      "examples": ["Car", "Jeep", "SUV", "Van (small)", "Pickup truck"],
      "licence_required": "LMV",
      "age_minimum": 18
    },
    "MCWG": {
      "full_name": "Motor Cycle With Gear",
      "description": "Motorcycles with gear system (above 50cc)",
      "examples": ["Bullet", "Pulsar", "Apache", "R15", "KTM Duke"],
      "licence_required": "MCWG",
      "age_minimum": 18,
      "category": "Two-Wheeler"
    },
    "MCWOG": {
      "full_name": "Motor Cycle Without Gear",
      "description": "Scooters and mopeds without gear (gearless)",
      "examples": ["Activa", "Dio", "Vespa", "Fascino", "Scooty"],
      "licence_required": "MCWOG",
      "age_minimum": 16,
      "category": "Two-Wheeler"
    },
    "HTV": {
      "full_name": "Heavy Transport Vehicle",
      "description": "GVW exceeding 12000 kg",
      "examples": ["Trucks", "Lorries", "Trailers", "Multi-axle vehicles"],
      "licence_required": "HTV",
      "age_minimum": 20
    },
    "HMV": {
      "full_name": "Heavy Motor Vehicle",
      "description": "Motor vehicle with GVW exceeding 12000 kg",
      "examples": ["Buses", "Large trucks"],
      "licence_required": "HMV",
      "age_minimum": 20
    },
    "MGV": {
      "full_name": "Medium Goods Vehicle",
      "description": "GVW between 7500 kg and 12000 kg",
      "examples": ["Mini trucks", "Canter", "Tempo traveller (goods)"],
      "licence_required": "MGV",
      "age_minimum": 18
    },
    "MPV": {
      "full_name": "Medium Passenger Vehicle",
      "description": "Passenger vehicles between LMV and HMV",
      "examples": ["Mini bus", "Large Tempo Traveller", "School bus (small)"],
      "licence_required": "MPV",
      "age_minimum": 18
    },
    "E_RICKSHAW": {
      "full_name": "Electric Rickshaw",
      "description": "Battery operated three-wheeled vehicles for passengers",
      "examples": ["E-rickshaw", "E-cart"],
      "licence_required": "LMV (special)",
      "age_minimum": 18,
      "max_speed_kmph": 25,
      "category": "Three-Wheeler"
    },
    "AUTO_RICKSHAW": {
      "full_name": "Auto Rickshaw / Three-Wheeler",
      "description": "Three-wheeled motorized vehicle",
      "examples": ["Auto", "Tuk-tuk", "Vikram"],
      "licence_required": "LMV + Badge",
      "age_minimum": 18,
      "category": "Three-Wheeler"
    }
  },
