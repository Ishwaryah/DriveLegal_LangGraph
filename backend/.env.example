# DriveLegal — Backend Environment Variables
# Copy this file to backend/.env and fill in your real keys.
# backend/.env is gitignored and will never be committed.

# ── Groq AI (Required) ────────────────────────────────────────────────────────
# Powers the /query and /agent/query agentic NLP endpoints (Llama 3.3 70B).
# Without this key the engine falls back to keyword matching + BM25 hybrid search.
# Get a free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── RapidAPI (Optional) ───────────────────────────────────────────────────────
# Enables live challan lookup and vehicle RC/DL info via Vahan/Sarathi.
# Without this key the app uses bundled offline snapshots.
# Subscribe at: https://rapidapi.com/search/vehicle-rc-information
RAPIDAPI_KEY=your_rapidapi_key_here

# ── Redis (Optional) ──────────────────────────────────────────────────────────
# Enables session persistence across requests.
# Without Redis, sessions are held in-process (lost on restart).
# Default: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
