{
  "_comment": "Runtime configuration for AgentEngine. Edit any value here — no Python code change required. Restart the server after editing.",

  "groq": {
    "_comment": "Groq LLM parameters. model_label appears in API responses.",
    "model": "llama-3.3-70b-versatile",
    "model_label": "groq-llama3",
    "max_tokens": 1024,
    "temperature": 0.1,
    "max_tool_iterations": 5
  },

  "hybrid_search": {
    "_comment": "Controls the NLP vector-search fallback.",
    "top_k": 3,
    "score_threshold": 0.15,
    "content_max_chars": 400,
    "rule_query_word_limit": 5
  },

  "hallucination_guard": {
    "_comment": "Safeguards against implausible model outputs.",
    "max_fine_amount_inr": 50000,
    "disclaimer": "⚠️ Informational only. Verify at echallan.parivahan.gov.in.",
    "verify_url": "https://echallan.parivahan.gov.in"
  },

  "fallback": {
    "_comment": "Keyword lists and canned responses for the keyword-only fallback path.",
    "greetings": [
      "hi", "hello", "hey", "good morning", "good evening",
      "good afternoon", "namaste", "namaskar", "jai hind",
      "hola", "howdy", "greetings", "sup", "yo"
    ],
    "fine_keywords": [
      "fine", "penalty", "challan", "amount", "how much", "cost",
      "charge", "fee", "bail", "jurmana", "jharama", "kitna"
    ],
    "rule_keywords": [
      "rule", "law", "legal", "section", "act", "allowed",
      "permitted", "regulation", "provision", "niyam", "kanoon"
    ],
    "zone_keywords": [
      "zone", "area", "here", "location", "nearby", "restriction",
      "limit", "boundary", "school zone", "no horn", "silent zone"
    ],
    "clarification_keywords": [
      "which state", "what state", "vehicle", "what city", "which city",
      "which vehicle", "what vehicle", "where are you", "your location"
    ],
    "not_found_keywords": [
      "couldn't find", "no data", "not found", "don't have",
      "unavailable", "no fine data", "no record", "not in database"
    ],
    "insufficient_info_keywords": [
      "gibberish", "rephrase", "sorry", "don't understand",
      "unclear", "invalid", "not a valid query"
    ],
    "greeting_response": "Hello! 👋 I'm DriveLegal AI — your Indian traffic law assistant.\n\nYou can ask me things like:\n• \"What's the fine for no helmet?\"\n• \"Drunk driving penalty in Tamil Nadu\"\n• \"What are the rules for using high beam?\"\n• \"Speed limit in a school zone\"\n\nHow can I help you today?",
    "unknown_query_response": "Sorry, I didn't understand that query. Try asking about a specific traffic rule or fine — e.g. 'fine for no helmet in Tamil Nadu'.",
    "no_info_response": "I couldn't find specific information. Please rephrase or consult echallan.parivahan.gov.in."
  },

